      document.getElementById('useDisplayTitleColor')?.addEventListener('input', (e) => { state.useDisplayTitleColor = e.target.value; render(); });
      document.getElementById('useDisplayBorderColor')?.addEventListener('input', (e) => { state.useDisplayBorderColor = e.target.value; render(); });
      
